PORT=8788
CAISHEN_HOST=0.0.0.0
CAISHEN_DATA_DIR=./data
CAISHEN_WORKSPACE_ID=local

# 生图服务：只在服务端配置，不会发送到浏览器。
CAISHEN_API_SERVICE_URL=
CAISHEN_API_BASE_URL=https://api.change2pro.com
CAISHEN_IMAGE_API_KEY=
CAISHEN_ANALYSIS_API_KEY=
CAISHEN_ANALYSIS_WIRE_API=chat_completions
# 旧版兼容：CAISHEN_API_KEY 只会作为 Image2 密钥迁移，不用于文字分析。
CAISHEN_API_KEY=
CAISHEN_IMAGE_MODEL=gpt-image-2
CAISHEN_REVERSE_PROMPT_MODEL=gpt-5-3
CAISHEN_FILE_TOKEN_SECRET=
CAISHEN_SESSION_SECRET=
